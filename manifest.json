{
  "name": "Randomizer",
  "description": "Randomize the speaking order of the participants in a call",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": ["tabs"],
  "host_permissions": ["https://meet.google.com/*"],
  "action": {
    "default_popup": "randomizer.html",
    "default_icon": "randomizer.png"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["randomizer.js"]
    }
  ]
}
